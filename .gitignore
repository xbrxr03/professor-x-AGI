# Rust build artifacts
professor-x/target/
jarvis/target/

# Reference repos (local study material, not project code)
_refs/

# Credential vault files — never committed
**/.professor-x/vault.key
**/.professor-x/vault.enc
**/.jarvis/vault.key
**/.jarvis/vault.enc

# OS noise
.DS_Store

# Nested professor-x/brain/ is reserved as runtime scratch only.
# Canonical research docs live at repo-root brain/.
# See professor-x/brain/STUB.md.
professor-x/brain/*
!professor-x/brain/STUB.md

# Runtime output (HIRO runs, transcripts, command logs, smoke). Evolution
# evidence is committed explicitly via the publish commands when wanted.
professor-x/artifacts/hiro/
professor-x/artifacts/transcripts/
professor-x/artifacts/commands/
professor-x/artifacts/coding-smoke/
professor-x/artifacts/coding-sessions/
professor-x/artifacts/replacements/
professor-x/artifacts/patches/

# Stray test files written by benchmark tasks
px-test.txt
professor-x/px-test.txt
*.tmp
